# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CDN_URL="https://cdn.sanchez.ph/mlbb/"

# Database (PostgreSQL)
# Local dev (docker compose up -d):
DATABASE_URL="postgresql://forge:forge_dev_password@localhost:5432/mlbb_forge?schema=public"
# Production (app connects to postgres container via Docker internal network):
# DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# Postgres credentials (used by docker-compose.prod.yml)
POSTGRES_USER="forge"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="mlbb_forge"

# Redis
# Local dev:
REDIS_URL="redis://localhost:6379"
# Production (with password, connects to redis container):
# REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"
REDIS_PASSWORD="change-me-in-production"

# Traefik / Let's Encrypt (prod only)
ACME_EMAIL="your-email@example.com"

# Auth.js
AUTH_SECRET="generate-a-strong-secret-key-here"
AUTH_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# OCI Object Storage (S3-Compatible API)
# Region: US West (Phoenix) → us-phoenix-1
OCI_NAMESPACE="axjnmgygqr0w"
OCI_BUCKET="cdn-bucket"
OCI_REGION="us-phoenix-1"
# All assets are uploaded under this prefix inside cdn-bucket (the "folder")
# Results in: cdn-bucket/mlbb/items/... → served as cdn.sanchez.ph/mlbb/items/...
OCI_OBJECT_PREFIX="mlbb"
# S3-compat endpoint: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_ENDPOINT="https://axjnmgygqr0w.compat.objectstorage.us-phoenix-1.oraclecloud.com"
# Generate these in OCI Console → Identity → Users → <your user> → Customer Secret Keys
OCI_ACCESS_KEY_ID="your-oci-access-key-id"
OCI_SECRET_ACCESS_KEY="your-oci-secret-access-key"
